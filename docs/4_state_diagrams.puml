@startuml
title State Diagrams (Institution Service & Application Service)

state "Institution Service (Laravel / PHP): Formation Lifecycle" as Formation {
  [*] --> BROUILLON : Création\n(Admin Établissement)
  
  state "BROUILLON" as BROUILLON
  state "PUBLIEE" as PUBLIEE
  state "ARCHIVEE" as ARCHIVEE

  BROUILLON --> PUBLIEE : publish()\n[Role: Admin Établissement]
  PUBLIEE --> ARCHIVEE : archive()\n[Role: Admin Établissement]

  note right of PUBLIEE
    Registration managed via
    separate RegistrationPeriod model:
    - is_open (boolean)
    - start_date / end_date
    - auto_close (boolean)
    - max_applications / current_applications
    Coordinator opens/closes via
    /registration-period/open | /close
  end note
}

--

state "Institution Service (Laravel / PHP): Registration Period" as RegPeriod {
  [*] --> Closed : Création (is_open=false)
  
  state "Closed" as Closed
  state "Open" as Open

  Closed --> Open : open()\n[Role: Coordinator]\n(sets is_open=TRUE)
  Open --> Closed : close()\n[Role: Coordinator]
  Open --> Closed : Scheduler Job\n(end_date < NOW, auto_close=true)
  Open --> Closed : Capacity Full\n(current_applications >= max_applications)
}

--

state "Application Service (Gin / Go): Inscription Lifecycle" as Inscription {
  [*] --> PREINSCRIPTION : CreateInscription\n[Role: Candidat]
  
  state "PREINSCRIPTION" as PREINSCRIPTION
  state "DOSSIER_SOUMIS" as DOSSIER_SOUMIS
  state "EN_VALIDATION" as EN_VALIDATION
  state "ACCEPTE" as ACCEPTE
  state "REFUSE" as REFUSE
  state "INSCRIT" as INSCRIT
  
  PREINSCRIPTION --> DOSSIER_SOUMIS : SubmitDossier\n(Upload via Document Service)
  DOSSIER_SOUMIS --> EN_VALIDATION : StartReview\n[Role: Admin Établissement]
  
  state AdminChoice <<choice>>
  EN_VALIDATION --> AdminChoice : MakeDecision
  AdminChoice --> ACCEPTE : Dossier accepté
  AdminChoice --> REFUSE : Dossier refusé
  
  ACCEPTE --> INSCRIT : FinalizeEnrollment\n(Paiement / Dépôt physique)
  
  REFUSE --> [*]
  INSCRIT --> [*]
}
@enduml