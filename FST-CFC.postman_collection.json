          }
        },
        {
          "name": "E2E Step 4 — Upload CIN Document",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{DOCUMENT_DIRECT}}/documents",
            "body": {
