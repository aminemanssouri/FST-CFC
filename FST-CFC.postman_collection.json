    {
      "name": "🔐 Auth Service (via Gateway)",
      "description": "Auth service runs at http://localhost:8001 and is also accessible via the gateway at http://localhost:3001/api/*",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{GATEWAY}}/api/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@fst-cfc.local\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            },
            "description": "Register a new user. Roles: candidat, establishment_admin, coordinator, super_admin"
          }
        },
        {
          "name": "Register — Admin Établissement",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{GATEWAY}}/api/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Etablissement\",\n  \"email\": \"admin@fst-cfc.local\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"establishment_admin\"\n}"
            }
          }
        },
        {
          "name": "Register — Coordinator",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{GATEWAY}}/api/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Coordinator User\",\n  \"email\": \"coordinator@fst-cfc.local\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"coordinator\"\n}"
            }
          }
        },
        {
          "name": "Login ★ (saves token automatically)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('TOKEN', json.token);",
                  "    pm.environment.set('TOKEN', json.token);",
                  "    console.log('Token saved:', json.token.slice(0,30) + '...');",
                  "} else if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('TOKEN', json.data.token);",
                  "    pm.environment.set('TOKEN', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{GATEWAY}}/api/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@fst-cfc.local\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Login and automatically save the JWT to {{TOKEN}}. Run this before any protected request."
          }
        },
