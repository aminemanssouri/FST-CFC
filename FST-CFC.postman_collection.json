    {
      "name": "🔁 End-to-End Flow",
      "description": "Run these in order to simulate the full candidate registration workflow:\n1. Login as candidate → get token\n2. Browse catalog → find formation\n3. Apply (create inscription)\n4. Upload documents\n5. Admin: review + transition inscription state\n6. Notification sent → check MailHog",
      "item": [
        {
          "name": "E2E Step 1 — Login as Candidate",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json.token || (json.data && json.data.token);",
                  "if (token) {",
                  "    pm.collectionVariables.set('TOKEN', token);",
                  "    pm.environment.set('TOKEN', token);",
                  "    console.log('✅ Candidate token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{GATEWAY}}/api/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@fst-cfc.local\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "E2E Step 2 — Browse Catalog",
          "request": {
            "method": "GET",
            "url": "{{GATEWAY}}/api/catalog",
            "description": "Find a formation ID to apply to."
          }
        },
        {
          "name": "E2E Step 3 — Apply to Formation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{APPLICATION_DIRECT}}/inscriptions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"formation_id\": 1,\n  \"notes\": \"Candidature pour la formation CFC.\"\n}"
