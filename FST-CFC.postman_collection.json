    {
      "name": "📋 Application Service — DIRECT :3005",
      "description": "⚠️ NOTE: The API Gateway routes /api/applications to http://application-service:3005 WITHOUT a path rewrite, but the Go service uses /inscriptions. Test this service DIRECTLY on port 3005.\n\nJWT roles used: CANDIDAT, ADMIN_ETABLISSEMENT, COORDINATEUR",
      "item": [
        {
          "name": "Health (Direct)",
          "request": {
            "method": "GET",
            "url": "{{APPLICATION_DIRECT}}/health"
          }
        },
        {
          "name": "[ADMIN/COORD] List All Inscriptions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{APPLICATION_DIRECT}}/inscriptions",
            "description": "Requires role ADMIN_ETABLISSEMENT or COORDINATEUR"
          }
        },
        {
          "name": "[Any] Get Single Inscription",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{APPLICATION_DIRECT}}/inscriptions/1",
            "description": "Owner can see their own. Admin can see all."
          }
        },
        {
          "name": "[CANDIDAT] Create Inscription (Apply)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{APPLICATION_DIRECT}}/inscriptions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"formation_id\": 1,\n  \"notes\": \"Je souhaite m'inscrire à cette formation.\"\n}"
            },
            "description": "Requires role CANDIDAT. Creates a new application (inscription) in PREINSCRIPTION state."
          }
        },
        {
          "name": "[ADMIN] Transition State",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{APPLICATION_DIRECT}}/inscriptions/1/transition",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to\": \"DOSSIER_SOUMIS\",\n  \"comment\": \"Dossier accepté pour traitement\"\n}"
            },
            "description": "Requires ADMIN_ETABLISSEMENT. Valid transitions: PREINSCRIPTION → DOSSIER_SOUMIS → EN_COURS_VALIDATION → ACCEPTE / REFUSE → INSCRIT"
          }
        },
        {
          "name": "[ADMIN] Transition — Accept",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{APPLICATION_DIRECT}}/inscriptions/1/transition",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to\": \"ACCEPTE\",\n  \"comment\": \"Dossier validé\"\n}"
            }
          }
        },
        {
          "name": "[ADMIN] Transition — Refuse",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{APPLICATION_DIRECT}}/inscriptions/1/transition",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to\": \"REFUSE\",\n  \"comment\": \"Dossier incomplet\"\n}"
            }
          }
        }
      ]
    },
