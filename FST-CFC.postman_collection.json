    {
      "name": "🔔 Notification Service (via Gateway + Direct :3007)",
      "description": "NestJS service. Sends emails via SMTP (MailHog on localhost:8025). Requires Idempotency-Key header.",
      "item": [
        {
          "name": "Health (Direct)",
          "request": {
            "method": "GET",
            "url": "{{NOTIFICATION_DIRECT}}/health"
          }
        },
        {
          "name": "Send Notification (via Gateway)",
          "request": {
            "method": "POST",
            "header": [
